<Window x:Class="JARVIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JARVIS"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="600" ResizeMode="CanMinimize">

    <Window.Resources>
        
        <Style x:Key="InfoLabel" TargetType="Label">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#39FF14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#39FF14" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BorderBase" TargetType="Border">
            <Setter Property="Background" Value="#CC0A0A0A"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#39FF14"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#39FF14" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonCircle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Background" Value="Red"/>
            <Setter Property="BorderBrush" Value="#FF111111"/>
            <Setter Property="BorderThickness" Value="5"/>
            <Setter Property="FontSize" Value="50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.05" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.05" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="circle"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="#39FF14" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="25" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.8" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="circle"
                                                            Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                            To="#AAFFAA" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.95" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.95" Duration="0:0:0.1"/>
                                            <ColorAnimation Storyboard.TargetName="circle"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="#BFFF00" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="35" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.1"/>
                                            <ColorAnimation Storyboard.TargetName="circle"
                                                            Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                            To="#FFFFFF" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="circle"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.4" Duration="0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Grid.Effect>
                                <DropShadowEffect x:Name="glow"
                                                  BlurRadius="0"
                                                  ShadowDepth="0"
                                                  Color="#39FF14"
                                                  Opacity="0"/>
                            </Grid.Effect>

                            <Ellipse x:Name="circle"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}"/>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonTextBlock" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#39FF14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#39FF14" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#CC0A0A0A"/>
            <Setter Property="Foreground" Value="#39FF14"/>
            <Setter Property="BorderBrush" Value="#39FF14"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#39FF14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#AAFFAA"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#39FF14" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#39FF14"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#39FF14" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Background" Value="#CC0A0A0A"/>
            <Setter Property="Foreground" Value="#39FF14"/>
            <Setter Property="BorderBrush" Value="#39FF14"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3939FF14"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#AAFFAA"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#39FF14" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5939FF14"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#39FF14" Opacity="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#555555"/>
                                <Setter TargetName="border" Property="Background" Value="#330A0A0A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <local:BoolToRecordingLabel x:Key="BoolToRecordingLabel"/>
        <local:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>

    <Border CornerRadius="5" BorderBrush="Black" BorderThickness="10">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="-1,-1" EndPoint="1,1" 
                                     SpreadMethod="Repeat">
                    <LinearGradientBrush.Transform>
                        <TranslateTransform x:Name="ShimmerTransform" X="-1" Y="1"/>
                    </LinearGradientBrush.Transform>
                    <GradientStop Color="#FF0A0A0A" Offset="0.0"/>
                    <GradientStop Color="#FF0A0A0A" Offset="0.35"/>
                    <GradientStop Color="#CC39FF14" Offset="0.40"/>
                    <GradientStop Color="#CC39FF14" Offset="0.45"/>
                    <GradientStop Color="#FF0A0A0A" Offset="0.50"/>
                    <GradientStop Color="#FF0A0A0A" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.Resources>
                <Storyboard x:Key="LoopShimmer" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="ShimmerTransform" Storyboard.TargetProperty="X" By="200" Duration="0:0:4" IsCumulative="True"/>
                    <DoubleAnimation Storyboard.TargetName="ShimmerTransform" Storyboard.TargetProperty="Y" By="1300" Duration="0:0:6" IsCumulative="True"/>
                </Storyboard>
            </Grid.Resources>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource LoopShimmer}"/>
                </EventTrigger>
            </Grid.Triggers>

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Label VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                   Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="3">
                <Border Style="{StaticResource BorderBase}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Label HorizontalContentAlignment="Center" Style="{StaticResource InfoLabel}">JARVIS</Label>
                        <Label Grid.Row="1" Style="{StaticResource InfoLabel}">Ваш ИИ помощник</Label>
                    </Grid>
                </Border>
            </Label>

            <Button Name="StartBut" 
                    Grid.Column="2" Grid.Row="1" Grid.RowSpan="2"
                    Style="{StaticResource ButtonCircle}" 
                    Content="{Binding IsRecording, Converter={StaticResource BoolToRecordingLabel}}"
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>

            <Button Name="FileBut" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Height="35" 
                    VerticalAlignment="Bottom" 
                    Style="{StaticResource NeonButton}" Content="Выберите exe файл"
                    Command="{Binding FileBrowseCommand}"/>

            <StackPanel Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,15,0,0">
                <Border Style="{StaticResource BorderBase}">
                    <TextBlock Name="FileName" Style="{StaticResource NeonTextBlock}" 
                               Text="{Binding FileName}" />
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border HorizontalAlignment="Left" Width="150" Height="40" 
                            Style="{StaticResource BorderBase}" Padding="0">
                        <TextBox Name="WordSpeak" Style="{StaticResource NeonTextBox}" 
                                 Text="{Binding WordSpeak}" />
                    </Border>
                    <Border HorizontalAlignment="Right" Width="60" Height="40" 
                            Style="{StaticResource BorderBase}" Margin="5,0,0,0" Padding="0">
                        <Button Name="SaveBut" Style="{StaticResource NeonButton}" Content="OK"
                                Command="{Binding SaveCommand}"/>
                    </Border>
                </StackPanel>

                <Border Width="auto" HorizontalAlignment="Left" Style="{StaticResource BorderBase}">
                    <TextBox Name="Status" 
         Style="{StaticResource NeonTextBox}"
                Text="{Binding Status}" 
                IsReadOnly="True"
                HorizontalScrollBarVisibility="Hidden"
                TextWrapping="NoWrap"
                Height="30" 
                Margin="5" />
                </Border>
            </StackPanel>

            <Button Name="OpenTXTBut" Grid.Column="3" Grid.Row="2" Grid.ColumnSpan="2" Grid.RowSpan="2" 
                    Width="200" Height="100" Style="{StaticResource NeonButton}" 
                    Command="{Binding OpenTxtCommand}">
                <TextBlock TextAlignment="Center">
                    Посмотреть выбранные<LineBreak/>файлы
                </TextBlock>
            </Button>

            <TextBox x:Name="BoxValueText" Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" Height="40"
                     Text="{Binding BoxValueText}" Style="{StaticResource NeonTextBox}"/>
            <TextBox x:Name="BoxOllamaText" Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2" Height="250"
                     Text="{Binding BoxOllamaText}" Style="{StaticResource NeonTextBox}"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Hidden" IsReadOnly="True"
                     Width="180"/>
        </Grid>
    </Border>
</Window>